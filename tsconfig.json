{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ES2022",
    "noImplicitAny": true,
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "types": ["vitest/globals"],
    "skipLibCheck": true,
    "rootDir": ".",
    "strict": true,
    "noEmit": false,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "outDir": "./dist",
    "paths": {
      "@Shared/*": ["./src/Contexts/Shared/*"],
      "@Apps/*": ["./src/apps/*"],
      "@Tests/*": ["./tests/*"],
      "@Tests/Contexts/Shared/*": ["./tests/Contexts/Shared/*"],
      "@Tests/Contexts/Core/*": ["./tests/Contexts/Core/*"],
      "@Core/*": ["./src/Contexts/Core/*"]
    }
  },
  "include": ["src/**/**.ts", "tests/**/**.ts"],
  "exclude": ["node_modules"]
}
